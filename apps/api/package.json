{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "test": "vitest run --exclude '**/*.isolation.spec.ts' --exclude '**/*.integration.spec.ts'",
    "test:integration:all": "vitest run --config vitest.integration.config.ts",
    "test:integration": "pnpm test:integration:all",
    "db:migrate": "bash ../../scripts/db/migrate-local.sh",
    "test:integration:tenants": "vitest run src/modules/tenants/tenants.isolation.spec.ts",
    "test:integration:inventario": "vitest run src/modules/inventario/inventario.isolation.spec.ts",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "db:check": "bash scripts/db-check.sh"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@posta/money": "workspace:*",
    "@posta/shared-types": "workspace:*",
    "@posta/validation": "workspace:*",
    "@supabase/supabase-js": "^2.47.0",
    "bullmq": "^5.77.0",
    "dotenv": "^16.0.0",
    "drizzle-orm": "^0.44.0",
    "fastify": "^5.0.0",
    "jsonwebtoken": "^9.0.2",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "xlsx": "^0.18.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.39.4",
    "globals": "^16.4.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "8.59.4",
    "vitest": "^3.0.0"
  }
}
