# Base de datos (Supabase → Settings → Database → Connection string → URI)
# Usar la URI de Transaction Pooler (puerto 6543) para producción con pgBouncer
# Usar Direct Connection (puerto 5432) para migraciones y tests de integración
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Supabase Project (Settings → API)
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # service_role key (NUNCA exponerla al cliente)
SUPABASE_ANON_KEY=eyJ...           # anon key

# JWT Secret para verificación local de tokens Supabase (Settings → API → JWT Settings)
SUPABASE_JWT_SECRET=your-jwt-secret

# Server
PORT=3001
# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGIN=http://localhost:3000

# Redis — requerido para el motor de importación (BullMQ)
REDIS_URL=redis://localhost:6379

# URL del frontend (invitaciones Supabase, redirectTo)
WEB_URL=http://localhost:3000

# Desactivar rate limit en dev/E2E (producción: omitir o THROTTLE_ENABLED=1)
THROTTLE_ENABLED=0

# Microservicio AFIP (opcional; sin esto usa FacturadorMock en la API)
# AFIP_SERVICE_URL=http://localhost:8000
