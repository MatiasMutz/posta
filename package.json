{
  "name": "posta",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build:packages": "pnpm --filter './packages/**' build",
    "dev:api": "THROTTLE_ENABLED=0 pnpm build:packages && pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm build:packages && pnpm --filter '!./packages/**' -r build",
    "test": "pnpm build:packages && pnpm -r test",
    "test:integration": "pnpm build:packages && pnpm --filter api test:integration:all",
    "test:e2e": "pnpm build:packages && bash scripts/ci/e2e-preflight.sh && pnpm --filter web test:e2e",
    "db:migrate": "bash scripts/db/migrate-local.sh",
    "lint": "pnpm --filter api lint && pnpm --filter web lint",
    "typecheck": "pnpm build:packages && pnpm -r typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22.13",
    "pnpm": ">=11"
  }
}
