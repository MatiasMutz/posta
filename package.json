{
  "name": "posta",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build:packages": "pnpm --filter './packages/**' build",
    "dev:api": "pnpm build:packages && pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm build:packages && pnpm --filter '!./packages/**' -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter web test:e2e",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
